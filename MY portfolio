<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ruth Ogohi — Virtual Assistant Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --maroon: #6B0F1A;
    --maroon-deep: #4A0910;
    --maroon-light: #8B1A27;
    --maroon-pale: #F9F0F1;
    --gold: #C9A84C;
    --cream: #FAF7F2;
    --dark: #1A1A1A;
    --text: #2D2D2D;
    --text-light: #666666;
    --white: #FFFFFF;
    --border: #E5E7EB;
    --light-bg: #F8F8F8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text);
    font-size: 16px;
    line-height: 1.7;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 4rem;
    background: rgba(250,247,242,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--gold);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem; font-weight: 700;
    color: var(--maroon);
  }
  .nav-links { display: flex; gap: 2rem; }
  .nav-links a {
    text-decoration: none;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--maroon); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 8rem 4rem 4rem;
    gap: 4rem;
  }
  .hero-text {}
  .hero-tag {
    display: inline-block;
    background: var(--maroon);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 3px;
    margin-bottom: 1.5rem;
  }
  .hero-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--dark);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }
  .hero-name span { color: var(--maroon); }
  .hero-title {
    font-size: 1.1rem;
    color: var(--text-light);
    margin-bottom: 1.5rem;
    font-style: italic;
  }
  .hero-desc {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 2rem;
    max-width: 500px;
  }
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    background: var(--maroon);
    color: white;
    padding: 0.85rem 2rem;
    border: none;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    cursor: pointer;
    transition: background 0.3s, transform 0.2s;
  }
  .btn-primary:hover { background: var(--maroon-deep); transform: translateY(-2px); }
  .btn-secondary {
    background: transparent;
    color: var(--maroon);
    padding: 0.85rem 2rem;
    border: 2px solid var(--maroon);
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    cursor: pointer;
    transition: all 0.3s;
  }
  .btn-secondary:hover { background: var(--maroon); color: white; }

  .hero-image { display: flex; justify-content: center; align-items: center; }
  .hero-img-wrap {
    width: 380px; height: 460px;
    position: relative;
  }
  .hero-img-wrap::before {
    content: '';
    position: absolute; top: 14px; left: 14px;
    width: 100%; height: 100%;
    border: 2.5px solid var(--maroon);
    border-radius: 6px;
    z-index: 0;
  }
  .hero-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    position: relative; z-index: 1;
    border-radius: 6px;
  }
  .hero-badge {
    position: absolute; bottom: -18px; right: -18px; z-index: 2;
    background: var(--maroon);
    color: white;
    padding: 1rem 1.2rem;
    border-radius: 6px;
    text-align: center;
    box-shadow: 0 8px 24px rgba(107,15,26,0.3);
  }
  .hero-badge .num { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; display: block; line-height: 1; }
  .hero-badge .lbl { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.85; }

  /* ── STATS ── */
  .stats {
    background: var(--maroon);
    padding: 2.5rem 4rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem; font-weight: 700;
    color: var(--gold);
    display: block; line-height: 1;
  }
  .stat-label { font-size: 0.8rem; color: rgba(255,255,255,0.8); margin-top: 0.4rem; text-transform: uppercase; letter-spacing: 0.08em; }

  /* ── SECTIONS ── */
  section { padding: 5rem 4rem; }
  .section-tag { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--maroon); margin-bottom: 0.5rem; }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .section-title em { color: var(--maroon); font-style: italic; }
  .section-sub { font-size: 1rem; color: var(--text-light); line-height: 1.8; max-width: 600px; margin-bottom: 3rem; }

  /* ── ABOUT ── */
  #about { background: white; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .about-text p { font-size: 1rem; line-height: 1.8; color: var(--text); margin-bottom: 1.2rem; }
  .about-highlights { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem; }
  .highlight-card {
    background: var(--maroon-pale);
    border-left: 4px solid var(--maroon);
    padding: 1rem 1.2rem;
    border-radius: 4px;
  }
  .highlight-card h4 { font-size: 0.9rem; font-weight: 700; color: var(--maroon); margin-bottom: 0.3rem; }
  .highlight-card p { font-size: 0.85rem; color: var(--text); line-height: 1.6; margin: 0; }

  /* ── SERVICES ── */
  #services { background: var(--maroon-pale); }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .service-card {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    transition: all 0.3s;
  }
  .service-card:hover { border-color: var(--maroon); transform: translateY(-4px); box-shadow: 0 12px 32px rgba(107,15,26,0.1); }
  .service-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }
  .service-name { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 600; color: var(--dark); margin-bottom: 0.8rem; }
  .service-desc { font-size: 0.9rem; line-height: 1.7; color: var(--text-light); }

  /* ── TOOLS ── */
  #tools { background: white; }
  .tools-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
  .tool-card {
    background: var(--light-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.2rem;
    text-align: center;
    transition: all 0.3s;
  }
  .tool-card:hover { border-color: var(--maroon); background: var(--maroon-pale); }
  .tool-icon { font-size: 1.8rem; display: block; margin-bottom: 0.5rem; }
  .tool-name { font-size: 0.85rem; font-weight: 600; color: var(--dark); }
  .tool-use { font-size: 0.75rem; color: var(--text-light); margin-top: 0.2rem; }

  /* ── WORK ── */
  #work { background: var(--maroon-pale); }
  .work-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .work-card {
    background: white;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all 0.3s;
  }
  .work-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(107,15,26,0.12); }
  .work-header { background: var(--maroon); padding: 1.8rem 2rem; }
  .work-stage { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 0.3rem; }
  .work-client { font-size: 0.75rem; color: rgba(255,255,255,0.7); margin-bottom: 0.3rem; }
  .work-title { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: white; margin-bottom: 0.5rem; }
  .work-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .work-tag {
    background: rgba(255,255,255,0.15);
    color: white;
    font-size: 0.7rem;
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
    font-weight: 500;
  }
  .work-body { padding: 2rem; }
  .work-desc { font-size: 0.9rem; line-height: 1.7; color: var(--text); margin-bottom: 1.2rem; }
  .work-deliverables { list-style: none; }
  .work-deliverables li {
    font-size: 0.88rem;
    color: var(--text);
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    line-height: 1.5;
  }
  .work-deliverables li::before { content: '✓'; color: var(--maroon); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
  .work-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--maroon);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1.5px solid var(--maroon);
    padding-bottom: 2px;
    transition: opacity 0.3s;
  }
  .work-link:hover { opacity: 0.7; }

  /* ── ACHIEVEMENT ── */
  .achievement-band {
    background: var(--maroon);
    padding: 3.5rem 4rem;
    text-align: center;
  }
  .achievement-band h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; font-weight: 700;
    color: var(--gold);
    margin-bottom: 0.8rem;
  }
  .achievement-band p { color: rgba(255,255,255,0.85); font-size: 1rem; line-height: 1.7; max-width: 650px; margin: 0 auto; }

  /* ── TESTIMONIALS ── */
  #testimonials { background: var(--dark); }
  #testimonials .section-tag { color: var(--gold); }
  #testimonials .section-title { color: white; }
  #testimonials .section-sub { color: rgba(255,255,255,0.5); }
  .testimonials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .testimonial-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 8px;
    padding: 2rem;
    position: relative;
  }
  .testimonial-card::before {
    content: '"';
    font-family: 'Playfair Display', serif;
    font-size: 5rem;
    color: var(--gold);
    opacity: 0.25;
    position: absolute;
    top: -10px; left: 16px;
    line-height: 1;
  }
  .testimonial-text {
    font-size: 0.95rem;
    font-style: italic;
    color: rgba(255,255,255,0.88);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    position: relative; z-index: 1;
  }
  .testimonial-author { display: flex; align-items: center; gap: 1rem; }
  .author-avatar {
    width: 44px; height: 44px;
    background: var(--maroon);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 1rem; font-weight: 700;
    color: white; flex-shrink: 0;
  }
  .author-name { font-weight: 600; font-size: 0.9rem; color: white; }
  .author-role { font-size: 0.78rem; color: rgba(255,255,255,0.45); }

  /* ── CONTACT ── */
  #contact { background: var(--cream); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .contact-item { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  .contact-icon {
    width: 44px; height: 44px;
    background: var(--maroon);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; color: white; flex-shrink: 0;
  }
  .contact-label { font-size: 0.75rem; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.1em; }
  .contact-value { font-size: 0.95rem; color: var(--dark); font-weight: 500; }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .contact-form input, .contact-form textarea {
    padding: 0.9rem 1.2rem;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    background: white;
    color: var(--text);
    transition: border-color 0.3s;
    outline: none;
  }
  .contact-form input:focus, .contact-form textarea:focus { border-color: var(--maroon); }
  .contact-form textarea { min-height: 130px; resize: vertical; }

  /* ── FOOTER ── */
  footer {
    background: var(--dark);
    color: rgba(255,255,255,0.5);
    text-align: center;
    padding: 2rem;
    font-size: 0.82rem;
  }
  footer span { color: var(--gold); }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; padding: 6rem 1.5rem 3rem; }
    .hero-image { display: none; }
    section { padding: 4rem 1.5rem; }
    .stats { grid-template-columns: repeat(2, 1fr); padding: 2rem 1.5rem; }
    .services-grid, .testimonials-grid, .contact-grid { grid-template-columns: 1fr; }
    .tools-grid { grid-template-columns: repeat(3, 1fr); }
    .work-grid { grid-template-columns: 1fr; }
    .about-grid { grid-template-columns: 1fr; }
    .about-highlights { grid-template-columns: 1fr; }
  }
</style>
</head>
